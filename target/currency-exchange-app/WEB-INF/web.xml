<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Currency Exchange App</display-name>

    <servlet>
        <servlet-name>CurrencyServlet</servlet-name>
        <servlet-class>servlet.CurrencyServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CurrencyApiServlet</servlet-name>
        <servlet-class>servlet.CurrencyApiServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CurrencyServlet</servlet-name>
        <url-pattern>/convert</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CurrencyApiServlet</servlet-name>
        <url-pattern>/api/convert</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
